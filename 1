import java.io.*;
import java.text.SimpleDateFormat;
import org.apache.poi.xssf.usermodel.*;
import org.apache.poi.ss.usermodel.DataFormatter; // Crucial for "Fail 1"
import org.apache.poi.ss.usermodel.DateUtil;

public class ExcelUtils {

    public static String[] readExcelData(String sheetName) throws Exception {
        String filePath = "OnlineReservation.xlsx";
        FileInputStream fis = new FileInputStream(new File(filePath));
        XSSFWorkbook workbook = new XSSFWorkbook(fis);
        XSSFSheet sheet = workbook.getSheet(sheetName);
        XSSFRow row = sheet.getRow(0); 
        
        int noOfColumns = row.getLastCellNum();
        String[] data = new String[noOfColumns];
        
        // DataFormatter reads the cell value as a String exactly as shown in Excel
        DataFormatter formatter = new DataFormatter();

        for (int i = 0; i < noOfColumns; i++) {
            XSSFCell cell = row.getCell(i);
            if (cell == null) {
                data[i] = "";
            } else if (DateUtil.isCellDateFormatted(cell)) {
                // For dates, the web form usually expects dd-mm-yyyy or dd/mm/yyyy
                SimpleDateFormat sdf = new SimpleDateFormat("dd-mm-yyyy");
                data[i] = sdf.format(cell.getDateCellValue());
            } else {
                data[i] = formatter.formatCellValue(cell);
            }
        }
        workbook.close();
        fis.close();
        return data;
    }
}



import java.io.*;
import java.text.DateFormat;
import java.text.SimpleDateFormat;
import java.util.Date;
import org.apache.poi.xssf.usermodel.*;
import org.apache.poi.ss.usermodel.DateUtil;
import org.apache.poi.ss.usermodel.DataFormatter;

public class ExcelUtils { 

    public static String[] readExcelData(String sheetName) throws Exception {
        String filePath = "OnlineReservation.xlsx";
        FileInputStream fis = new FileInputStream(new File(filePath));
        XSSFWorkbook workbook = new XSSFWorkbook(fis);
        XSSFSheet sheet = workbook.getSheet(sheetName);
        XSSFRow row = sheet.getRow(0); 
        
        int noOfColumns = row.getLastCellNum();
        String[] data = new String[noOfColumns];
        DataFormatter formatter = new DataFormatter();

        for (int i = 0; i < noOfColumns; i++) {
            XSSFCell cell = row.getCell(i);
            if (cell == null) {
                data[i] = "";
                continue;
            }

            switch (cell.getCellType()) {
                case STRING:
                    data[i] = cell.getStringCellValue();
                    break;
                case NUMERIC:
                    if (DateUtil.isCellDateFormatted(cell)) {
                        // REVISED: Convert Excel Date (2040-09-12) to Web Format (22/08/2022)
                        Date dateValue = cell.getDateCellValue();
                        DateFormat df = new SimpleDateFormat("dd/MM/yyyy"); 
                        data[i] = df.format(dateValue);
                    } else {
                        data[i] = formatter.formatCellValue(cell);
                    }
                    break;
                default:
                    data[i] = "";
            }
        }
        workbook.close();
        return data;
    }
}




